@prefix ex:   <http://example.org/defect#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ─── Classes ────────────────────────────────────────────────────────────────

ex:DefectType a owl:Class ;
    rdfs:label "Defect Type" .

ex:Cause a owl:Class ;
    rdfs:label "Cause" .

ex:Action a owl:Class ;
    rdfs:label "Recommended Action" .

# ─── Properties ─────────────────────────────────────────────────────────────

ex:promptTemplate a owl:DatatypeProperty ;
    rdfs:domain ex:DefectType ;
    rdfs:range  xsd:string ;
    rdfs:comment "CLIP prompt template; use '{}' as placeholder for the object class name." .

ex:applicableToClass a owl:DatatypeProperty ;
    rdfs:domain ex:DefectType ;
    rdfs:range  xsd:string ;
    rdfs:comment "Object class name (e.g. MVTec AD folder name) for which this defect type is physically plausible. Repeat the triple for each applicable class. If no triple is present the defect type is considered universal." .

ex:hasCause a owl:ObjectProperty ;
    rdfs:domain ex:DefectType ;
    rdfs:range  ex:Cause .

ex:recommendedAction a owl:ObjectProperty ;
    rdfs:domain ex:DefectType ;
    rdfs:range  ex:Action .

# ─── Causes ─────────────────────────────────────────────────────────────────

ex:AbrasiveContact a ex:Cause ;
    rdfs:label "abrasive contact" .

ex:MechanicalImpact a ex:Cause ;
    rdfs:label "mechanical impact" .

ex:MaterialFatigue a ex:Cause ;
    rdfs:label "material fatigue" .

ex:ProcessContamination a ex:Cause ;
    rdfs:label "process contamination" .

ex:AssemblyError a ex:Cause ;
    rdfs:label "assembly error" .

ex:WearAndTear a ex:Cause ;
    rdfs:label "wear and tear" .

ex:ManufacturingDefect a ex:Cause ;
    rdfs:label "manufacturing defect" .

# ─── Actions ────────────────────────────────────────────────────────────────

ex:LineStop a ex:Action ;
    rdfs:label "stop production line" .

ex:ReplaceGuideRail a ex:Action ;
    rdfs:label "replace guide rail" .

ex:CleanSurface a ex:Action ;
    rdfs:label "clean surface" .

ex:ReplaceComponent a ex:Action ;
    rdfs:label "replace component" .

ex:InspectTool a ex:Action ;
    rdfs:label "inspect tooling" .

ex:ScrapPart a ex:Action ;
    rdfs:label "scrap part" .

ex:AdjustProcess a ex:Action ;
    rdfs:label "adjust process parameters" .

# ─── Defect Types ────────────────────────────────────────────────────────────
# Prompts describe visual appearance seen in industrial top-down inspection images.
# Each type uses distinct visual language to minimise overlap with other types.

ex:Crack a ex:DefectType ;
    rdfs:label "crack" ;
    ex:promptTemplate "a top view of a {} with a thin crack on the surface" ;
    ex:promptTemplate "a photo of a {} with a hairline fracture" ;
    ex:promptTemplate "a photo of a {} with a linear crack visible on the rim" ;
    ex:promptTemplate "a close-up of a {} with a narrow crack running across the surface" ;
    ex:applicableToClass "";
    ex:hasCause ex:MechanicalImpact ;
    ex:hasCause ex:MaterialFatigue ;
    ex:recommendedAction ex:LineStop ;
    ex:recommendedAction ex:ScrapPart .

ex:Scratch a ex:DefectType ;
    rdfs:label "scratch" ;
    ex:promptTemplate "{} with visible scratches on the surface" ;
#    ex:promptTemplate "{} with scratch marks" ;
#    ex:promptTemplate "{} with fine surface scratches" ;
#    ex:promptTemplate "{} showing surface scratches" ;
    ex:applicableToClass "metal_nut";
    ex:hasCause ex:AbrasiveContact ;
    ex:hasCause ex:WearAndTear ;
    ex:recommendedAction ex:ReplaceGuideRail ;
    ex:recommendedAction ex:InspectTool .

ex:Chip a ex:DefectType ;
    rdfs:label "chip" ;
    ex:promptTemplate "a top view of a {} with a small piece of glass missing from the rim" ;
    ex:promptTemplate "a photo of a {} with a small chip on the opening edge" ;
    ex:promptTemplate "a close-up of a {} with a minor chip showing exposed material" ;
    ex:promptTemplate "an industrial inspection photo of a {} with a small broken piece on the rim" ;
    ex:applicableToClass "bottle";
    ex:hasCause ex:MechanicalImpact ;
    ex:recommendedAction ex:ScrapPart ;
    ex:recommendedAction ex:InspectTool .

ex:Bend a ex:DefectType ;
    rdfs:label "bend" ;
    ex:promptTemplate "a photo of a {} with a visibly bent or warped section" ;
    ex:promptTemplate "a top view of a {} with an asymmetric deformed shape" ;
    ex:promptTemplate "an industrial inspection photo of a {} showing deformation" ;
    ex:promptTemplate "a photo of a {} with a curved or bowed structure" ;
    ex:applicableToClass "metal_nut";
    ex:hasCause ex:MechanicalImpact ;
    ex:hasCause ex:AssemblyError ;
    ex:recommendedAction ex:AdjustProcess ;
    ex:recommendedAction ex:ScrapPart .

ex:Contamination a ex:DefectType ;
    rdfs:label "contamination" ;
#    ex:promptTemplate "a top view of a {} with foreign object visible inside" ;
    ex:promptTemplate "a top down photo of a {} with unwanted material protruding from the opening" ;
#    ex:promptTemplate "a visual inspection photo of a {} with a contaminating object inside" ;
    ex:applicableToClass "bottle";
    ex:hasCause ex:ProcessContamination ;
    ex:recommendedAction ex:CleanSurface ;
    ex:recommendedAction ex:AdjustProcess .

ex:Stain a ex:DefectType ;
    rdfs:label "color" ;
    ex:promptTemplate "a photo of a {} with a dark stain on the outer surface" ;
    ex:promptTemplate "a top view of a {} with colour marks caused by liquid on the surface" ;
    ex:promptTemplate "a photo of a {} with staining on the exterior" ;
    ex:promptTemplate "an industrial inspection photo of a {} with dried liquid residue on the surface" ;
    ex:applicableToClass "metal_nut";
    ex:hasCause ex:ProcessContamination ;
    ex:hasCause ex:WearAndTear ;
    ex:recommendedAction ex:CleanSurface .

ex:MissingPart a ex:DefectType ;
    rdfs:label "missing part" ;
    ex:promptTemplate "a top view of a {} with a large section completely missing" ;
    ex:promptTemplate "a photo of a {} with an entire component absent" ;
    ex:promptTemplate "an industrial inspection photo of a {} where a key part is not present" ;
    ex:promptTemplate "a photo of a {} with a large gap where a structural part should be" ;
    ex:applicableToClass "";
    ex:hasCause ex:AssemblyError ;
    ex:hasCause ex:ManufacturingDefect ;
    ex:recommendedAction ex:LineStop ;
    ex:recommendedAction ex:ReplaceComponent .

ex:Break a ex:DefectType ;
    rdfs:label "break" ;
    ex:promptTemplate "a top view of a {} with a large piece of the rim broken off" ;
    ex:promptTemplate "a photo of a {} with a large fragment missing from the glass edge" ;
    ex:promptTemplate "an industrial inspection photo of a {} with a large break exposing the interior" ;
    ex:promptTemplate "a photo of a {} with a significant portion of the opening shattered" ;
    ex:applicableToClass "bottle";
    ex:hasCause ex:MechanicalImpact ;
    ex:hasCause ex:MaterialFatigue ;
    ex:recommendedAction ex:LineStop ;
    ex:recommendedAction ex:ScrapPart .

ex:Thread a ex:DefectType ;
    rdfs:label "thread" ;
    ex:promptTemplate "a top view of a {} with a thread or fibre lying across the surface" ;
    ex:promptTemplate "a photo of a {} with a thin fibre contaminating the opening" ;
    ex:promptTemplate "an industrial inspection photo of a {} with a strand of thread inside" ;
    ex:promptTemplate "a photo of a {} with a loose thread visible on the rim" ;
    ex:applicableToClass "";
    ex:hasCause ex:ProcessContamination ;
    ex:recommendedAction ex:CleanSurface ;
    ex:recommendedAction ex:InspectTool .